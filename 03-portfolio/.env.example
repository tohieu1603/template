NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false
DB_SYNC=true
DB_LOGGING=false
JWT_ACCESS_SECRET=random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=random_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
LOG_LEVEL=info
LOG_DIR=logs
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
